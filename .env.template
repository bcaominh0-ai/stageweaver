# StageWeaver local template.
# Copy to .env and fill real values locally. Do not commit .env.

# LLM endpoints. Leave keys blank until the user provides real credentials.
OPENAI_BASE_URL=http://127.0.0.1:8000/v1
OPENAI_API_KEY=
JUDGE_BASE_URL=http://127.0.0.1:8000/v1
JUDGE_API_KEY=
JUDGE_MODEL=

# Agent model names and optional local paths. Do not point these at large
# checkpoints unless you intentionally want to run local model smoke tests.
META_MODEL=
EXEC_MODEL=
META_MODEL_PATH=
EXEC_MODEL_PATH=
LOCAL_MODEL_PATH=
LOCAL_MODEL_DTYPE=bfloat16

# Search backend. server/search_tool.py reads SEARXNG_HOST; SEARXNG_URL is
# included for compatibility with Memento-style env files.
SEARXNG_URL=http://127.0.0.1:8080
SEARXNG_HOST=http://127.0.0.1:8080

# Crawl extraction endpoint, if ai_crawl.py should call an OpenAI-compatible
# model after crawling. Leave key blank until configured.
CRAWL_EXTRACT_BASE_URL=http://127.0.0.1:8000/v1
CRAWL_EXTRACT_API_KEY=
CRAWL_EXTRACT_MODEL=

# Semantic retriever cache and small embedding model.
HF_HOME=hf_cache
MODELSCOPE_CACHE=hf_cache/modelscope
SEMANTIC_MODEL_ID=AI-ModelScope/bge-small-en-v1.5
SEMANTIC_CACHE_DIR=hf_cache/modelscope

# StageWeaver artifacts.
STAGEWEAVER_BANK_JSONL=result/stageweaver/current/stage_bank/stage_bank_train.jsonl
STAGEWEAVER_COMPOSER_CKPT=result/stageweaver/current/append_sft/stageweaver_composer_sft.pt
