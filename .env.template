# StageWeaver local template.
# Copy to .env and fill real values locally. Do not commit .env.

# LLM endpoints. Leave keys blank until the user provides real credentials.
OPENAI_BASE_URL=http://127.0.0.1:8000/v1
OPENAI_API_KEY=
JUDGE_BASE_URL=http://127.0.0.1:8000/v1
JUDGE_API_KEY=
JUDGE_MODEL=

# Teacher model for generating StageWeaver training trajectories.
TEACHER_BASE_URL=
TEACHER_API_KEY=
TEACHER_MODEL=Qwen/Qwen2.5-72B-Instruct-128K
TEACHER_BYPASS_PROXY=1
OPENAI_REQUEST_TIMEOUT_SEC=120

# Agent model names and optional local paths. Do not point these at large
# checkpoints unless you intentionally want to run local model smoke tests.
META_MODEL=
EXEC_MODEL=
META_MODEL_PATH=
EXEC_MODEL_PATH=
LOCAL_MODEL_PATH=
LOCAL_MODEL_DTYPE=bfloat16

# Search backend. server/search_tool.py reads SEARXNG_HOST; SEARXNG_URL is
# included for compatibility with Memento-style env files.
SEARXNG_URL=http://119.45.1.210
SEARXNG_HOST=http://119.45.1.210
SEARXNG_SEARCH_TIMEOUT_SEC=30
SEARXNG_SEARCH_ATTEMPTS=2
SEARXNG_API_STYLE=api
SEARXNG_API_KEY=
SEARXNG_API_KEY_PLACEMENT=query
SEARXNG_API_KEY_PARAM=api_key
SEARXNG_API_KEY_HEADER=X-API-Key
SEARXNG_LANGUAGE_PARAM=lang
SEARXNG_ENGINES=bing

# Crawl retries absorb brief proxy-tunnel interruptions. The outer MCP tool
# timeout defaults to 75 seconds and can be overridden independently.
CRAWL_PAGE_TIMEOUT_SEC=30
CRAWL_ATTEMPTS=2
STAGEWEAVER_TOOL_CALL_TIMEOUT_SEC=75

# Crawl extraction endpoint, if ai_crawl.py should call an OpenAI-compatible
# model after crawling. Leave key blank until configured.
CRAWL_EXTRACT_BASE_URL=http://127.0.0.1:8000/v1
CRAWL_EXTRACT_API_KEY=
CRAWL_EXTRACT_MODEL=
CRAWL_EXTRACT_BYPASS_PROXY=1
CRAWL_EXTRACT_REQUEST_TIMEOUT_SEC=60
CRAWL_EXTRACT_MAX_INPUT_CHARS=12000

# Optional remote crawl API. Prefer this over search-only fallback when the
# search API host can directly fetch public web pages.
REMOTE_CRAWL_EXTRACT_URL=http://119.45.1.210/crawl_extract
REMOTE_CRAWL_EXTRACT_API_KEY=
REMOTE_CRAWL_EXTRACT_TIMEOUT_SEC=60
REMOTE_CRAWL_EXTRACT_BYPASS_PROXY=1

# Optional audio transcription endpoint for server/documents_tool.py.
# This should be an OpenAI-compatible audio transcription API.
AUDIO_TRANSCRIPTION_BASE_URL=
AUDIO_TRANSCRIPTION_API_KEY=
AUDIO_TRANSCRIPTION_MODEL=qwen3-omni-flash-all

# Optional Somark parser for PDFs and supported image/pdf document types.
SOMARK_BASE_URL=https://www.dmxapi.cn/v1/responses
SOMARK_API_KEY=
SOMARK_MODEL=somark

# Optional crawl reranker. If left blank, ai_crawl.py reuses
# CRAWL_EXTRACT_* / JUDGE_* credentials and defaults to Qwen/Qwen3-Reranker-8B.
CRAWL_RERANK_BASE_URL=
CRAWL_RERANK_API_KEY=
CRAWL_RERANK_MODEL=Qwen/Qwen3-Reranker-8B
CRAWL_RERANK_CANDIDATES=32
CRAWL_RERANK_DOC_CHARS=2500
CRAWL_RERANK_TIMEOUT=30

# Semantic retriever cache and small embedding model.
HF_HOME=hf_cache
MODELSCOPE_CACHE=hf_cache/modelscope
SEMANTIC_MODEL_ID=AI-ModelScope/bge-small-en-v1.5
SEMANTIC_CACHE_DIR=hf_cache/modelscope

# StageWeaver artifacts.
STAGEWEAVER_BANK_JSONL=result/stageweaver/current/stage_bank/stage_bank_train.jsonl
STAGEWEAVER_COMPOSER_CKPT=result/stageweaver/current/append_sft/stageweaver_composer_sft.pt

# Optional failure-insight distillation agent used by build_stageweaver_bank
# when --distill_failure_insights is enabled.
INSIGHT_BASE_URL=
INSIGHT_API_KEY=
INSIGHT_MODEL=gemini-3.1-flash-lite

